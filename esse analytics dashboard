function renderContenuti(){
  const ig=filter(igRaw), tt=filter(ttRaw);
  if(!ig.length&&!tt.length){document.getElementById('b-contenuti').innerHTML='<div class="empty">Carica i dati</div>';return;}
  const all=[];
  ig.forEach(r=>all.push({date:r.date,plat:'ig',title:r.caption||'—',type:r.type||'post',eng:r.likes+r.comments+r.shares+r.saves,er:r.followers>0?((r.likes+r.comments+r.shares+r.saves)/r.followers*100):0}));
  tt.forEach(r=>all.push({date:r.date,plat:'tt',title:r.title||'—',type:'video',eng:r.likes+r.comments+r.shares,er:r.followers>0?((r.likes+r.comments+r.shares)/r.followers*100):0}));
  all.sort((a,b)=>b.eng-a.eng);
  const top=all.slice(0,60);
  const maxE=top[0]?top[0].eng:1;
  const bt={};ig.forEach(r=>{if(!bt[r.type])bt[r.type]={n:0,e:0};bt[r.type].n++;bt[r.type].e+=r.likes+r.comments+r.shares+r.saves;});
  const sorted=Object.entries(bt).sort((a,b)=>b[1].e/b[1].n-a[1].e/a[1].n);
  const best=sorted[0];

  document.getElementById('b-contenuti').innerHTML=`
    ${best?heroNum('Formato top', best[0].toUpperCase(), `${fmt(Math.round(best[1].e/best[1].n))} interazioni medie per post · il contenuto più efficace`, null, true):''}
    ${secLabel('Performance per formato · Instagram')}
