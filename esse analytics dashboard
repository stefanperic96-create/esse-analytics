    ...(opts.extra||{})
  }});
}

function secLabel(txt){
  return `<div style="font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--g3);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><span style="display:inline-block;width:20px;height:1px;background:var(--g3);"></span>${txt}</div>`;
}

function heroNum(label, number, sub, deltaVal, deltaUp){
  const delta = deltaVal ? `<div class="hero-delta ${deltaUp?'up':'dn'}">${deltaVal}</div>` : '';
  return `<div class="hero-section anim">
    <div class="hero-label">${label}</div>
    <div class="hero-number">${number}</div>
    <div class="hero-sub">${sub}</div>
    ${delta}
  </div>`;
}

function metricCard(label, val, delta, cls='', accent=false, dark=false){
  return `<div class="metric${accent?' accent':''}${dark?' dark':''}">
    <div class="m-label">${label}</div>
    <div class="m-val">${val}</div>
    <div class="m-delta ${cls}">${delta}</div>
  </div>`;
}

