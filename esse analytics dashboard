function renderInsights(){
  const ig=filter(igRaw), tt=filter(ttRaw);
  if(!ig.length&&!tt.length){document.getElementById('b-insights').innerHTML='<div class="empty">Carica i dati</div>';return;}
  const ins=[], recs=[];

  if(ig.length>1){
    const g=ig[ig.length-1].followers-ig[0].followers;
    const pct=(g/Math.max(ig[0].followers,1)*100).toFixed(1);
    ins.push({style:'yellow',type:'Crescita Instagram',title:(g>=0?'+':'')+fmt(g)+' follower',body:`In ${plabel()} il profilo IG ha guadagnato ${g>=0?'+':''}${fmt(g)} follower (${g>=0?'+':''}${pct}%). ${g>500?'Crescita solida — mantieni la frequenza attuale.':'Attenzione: valuta variazioni nella strategia di contenuto.'}`,stat:(g>=0?'+':'')+fmt(g)});
    const er=(ig.reduce((s,r)=>s+(r.likes+r.comments+r.shares+r.saves)/Math.max(r.followers,1)*100,0)/ig.length).toFixed(2);
    ins.push({style:parseFloat(er)>2?'':'dark',type:'Engagement rate',title:`Instagram: ${er}%`,body:parseFloat(er)>3?`Ottimo — sopra la media del settore (3%). I contenuti generano partecipazione autentica.`:parseFloat(er)>1.5?`Nella media (1.5–3%). Margine con contenuti che generano salvataggi.`:`Sotto la media. Focus su contenuti salvabili e condivisibili.`,stat:er+'%'});
    const bt={};ig.forEach(r=>{if(!bt[r.type])bt[r.type]={n:0,e:0};bt[r.type].n++;bt[r.type].e+=r.likes+r.comments+r.shares+r.saves;});
    const best=Object.entries(bt).sort((a,b)=>b[1].e/b[1].n-a[1].e/a[1].n)[0];
    if(best)ins.push({style:'',type:'Formato vincente',title:`"${best[0]}" domina`,body:`In media ${fmt(Math.round(best[1].e/best[1].n))} interazioni — il tuo formato più efficace nel periodo. Aumenta la produzione di questo tipo.`,stat:fmt(Math.round(best[1].e/best[1].n))+' eng/post'});
  }
  if(tt.length>1){
    const g=tt[tt.length-1].followers-tt[0].followers;
    ins.push({style:g>=0?'yellow':'dark',type:'Crescita TikTok',title:(g>=0?'+':'')+fmt(g)+' follower',body:`In ${plabel()} TikTok ha variato di ${g>=0?'+':''}${fmt(g)} follower. ${g>1000?'Forte crescita organica — TikTok è il canale più dinamico.':'Crescita stabile. Prova ad aumentare frequenza a 1–2 video/giorno.'}`,stat:(g>=0?'+':'')+fmt(g)});
    const avgV=tt.reduce((s,r)=>s+r.views,0)/tt.length;
    const viral=tt.filter(r=>r.views>avgV*3);
    if(viral.length)ins.push({style:'',type:'Contenuti virali',title:`${viral.length} video oltre 3× la media`,body:`${viral.length} video hanno superato 3× la media di ${fmt(Math.round(avgV))} views. Analizza titolo, argomento e orario di pubblicazione — e replica il pattern.`,stat:viral.length+' video virali'});
  }
  if(ig.length&&tt.length){
    const igER=ig.reduce((s,r)=>s+(r.likes+r.comments+r.shares+r.saves)/Math.max(r.followers,1)*100,0)/ig.length;
    const ttER=tt.reduce((s,r)=>s+(r.likes+r.comments+r.shares)/Math.max(r.followers,1)*100,0)/tt.length;
    ins.push({style:'dark',type:'Confronto canali',title:`${igER>ttER?'Instagram':'TikTok'} più efficiente`,body:`Confrontando l'engagement rate per follower, ${igER>ttER?'Instagram':'TikTok'} genera più interazioni proporzionalmente. Priorità: aumenta la frequenza lì e cross-posta i top performer.`,stat:''});
  }

  recs.push({type:'Raccomandazione',title:'Pubblica 18–20h ogni giorno feriale',body:'La finestra oraria con il massimo di reach organica. Programma i contenuti principali qui — anche nei weekend sabato supera venerdì.'});
  recs.push({type:'Raccomandazione',title:'Cross-posting strategico',body:'I contenuti con più engagement su IG vanno adattati con hook diverso e riproposti su TikTok — e viceversa. Raddoppi la reach con lo stesso sforzo creativo.'});
  recs.push({type:'Raccomandazione',title:'Salvataggi come KPI principale',body:'I post con molti salvataggi su IG hanno valore a lungo termine nell\'algoritmo. Priorità a contenuti utili e salvabili: classifiche, approfondimenti, guide artisti.'});
  recs.push({type:'Raccomandazione',title:'Report mensile',body:`Carica i dati ogni mese per tracciare il trend. La comparazione periodo su periodo è lo strumento più efficace per capire cosa sta funzionando davvero.`});

  document.getElementById('b-insights').innerHTML=`
    ${secLabel('Insights automatici · '+plabel())}
    <div class="ins-grid anim anim-d1">${ins.map(c=>`<div class="ins-card ${c.style}">
      <div class="ins-type">${c.type}</div>
      <div class="ins-title">${c.title}</div>
      <div class="ins-body">${c.body}</div>
      ${c.stat?`<div class="ins-stat">${c.stat}</div>`:''}
    </div>`).join('')}</div>
    ${secLabel('Raccomandazioni operative')}
    <div class="ins-grid anim anim-d2">${recs.map(c=>`<div class="ins-card">
      <div class="ins-type">${c.type}</div>
      <div class="ins-title">${c.title}</div>
      <div class="ins-body">${c.body}</div>
    </div>`).join('')}</div>`;
}
</script>
</body>
</html>
