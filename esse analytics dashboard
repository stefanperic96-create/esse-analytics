function renderPresentazione(){
  const ig=filter(igRaw), tt=filter(ttRaw);
  if(!ig.length&&!tt.length){document.getElementById('b-presentazione').innerHTML='<div class="empty">Carica i dati</div>';return;}
  const igF=ig.length?ig[ig.length-1].followers:0, igG=ig.length>1?igF-ig[0].followers:0;
