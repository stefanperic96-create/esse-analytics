    ${secLabel('Tutti i post · ordinati per engagement · '+plabel())}
    <div class="tbl-wrap anim anim-d2">
      <table>
        <thead><tr>
          <th>Data</th><th>Canale</th><th>Tipo</th><th>Contenuto</th><th>Engagement</th><th>Eng%</th>
        </tr></thead>
        <tbody>${top.map(p=>`<tr>
          <td style="font-size:10px;color:var(--g3);white-space:nowrap;">${p.date.toLocaleDateString('it')}</td>
          <td><span class="plat-badge ${p.plat==='ig'?'plat-ig':'plat-tt'}">${p.plat.toUpperCase()}</span></td>
          <td style="font-size:10px;color:var(--g4);">${p.type}</td>
          <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px;">${p.title}</td>
          <td><div class="eng-bar-wrap"><div class="eng-bar" style="width:${Math.round(p.eng/maxE*70)}px;max-width:70px"></div><span style="font-size:11px;color:var(--g4);margin-left:4px;">${fmt(p.eng)}</span></div></td>
          <td style="font-size:11px;font-weight:600;color:${p.er>2?'var(--k)':'var(--g4)'};">${p.er.toFixed(2)}%</td>
