<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
// ═══════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════
let igRaw=null, ttRaw=null, activePeriod=30, charts={};
const TITLES={upload:'Carica dati',overview:'Overview',instagram:'Instagram',tiktok:'TikTok',reazioni:'Reazioni',audience:'Audience',orari:'Orari migliori',contenuti:'Contenuti',benchmark:'Benchmark',calendario:'Calendario',presentazione:'Presentazione',insights:'Insights'};

// ═══════════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════════
function nav(id, btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.s-item').forEach(b=>b.classList.remove('on'));
  const pg = document.getElementById('p-'+id);
  pg.classList.add('on');
  pg.style.animation = 'fadeIn .35s cubic-bezier(0.16,1,0.3,1) both';
  setTimeout(()=>pg.style.animation='',400);
  if(btn) btn.classList.add('on');
  document.getElementById('tb-title').textContent = TITLES[id]||id;
}

function period(d, btn){
  activePeriod = d;
  document.querySelectorAll('.pb').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  if(igRaw||ttRaw) renderAll();
}

function plabel(){
  if(activePeriod>=99999) return 'tutto il periodo';
  if(activePeriod===365) return '1 anno';
  if(activePeriod===180) return '6 mesi';
  return activePeriod+' giorni';
}

// ═══════════════════════════════════════════════════════
// CSV PARSER
// ═══════════════════════════════════════════════════════
function parseCSV(text){
  text = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n').trim();
  if(!text) return [];
  const lines = text.split('\n');
  const first = lines[0];
  let delim = ',';
  if(first.split(';').length > first.split(',').length) delim=';';
  else if(first.split('\t').length > first.split(',').length) delim='\t';

  function splitLine(l){
    const f=[]; let c='', q=false;
    for(let i=0;i<l.length;i++){
      const ch=l[i];
      if(q){ if(ch==='"'){ if(l[i+1]==='"'){c+='"';i++;}else q=false; } else c+=ch; }
      else{ if(ch==='"') q=true; else if(ch===delim){f.push(c);c='';} else c+=ch; }
    }
    f.push(c); return f;
  }
  function cast(v){
    const s=(v||'').trim().replace(/^"|"$/g,'');
    if(!s||s==='-'||s.toLowerCase()==='null') return null;
    const n=Number(s.replace(',','.'));
    return isNaN(n)?s:n;
  }
  const hdrs = splitLine(lines[0]).map(h=>h.trim().replace(/^"|"$/g,''));
  const rows = [];
  for(let i=1;i<lines.length;i++){
    if(!lines[i].trim()) continue;
    const vals = splitLine(lines[i]);
    const row = {};
    hdrs.forEach((h,idx)=>row[h]=cast(vals[idx]));
    rows.push(row);
  }
  return rows;
}

function findCol(row, opts){
  const keys = Object.keys(row).map(k=>k.toLowerCase().trim());
  for(const o of opts){
    const i = keys.findIndex(k=>k.includes(o.toLowerCase()));
    if(i>=0) return Object.keys(row)[i];
  }
  return null;
}

function normalizeIG(rows){
  if(!rows.length) return [];
  const r=rows[0];
  const c={
    date:   findCol(r,['date','data','giorno','day','periodo']),
    foll:   findCol(r,['follower','fan','subscriber']),
    reach:  findCol(r,['reach','copertura']),
    imp:    findCol(r,['impression','views','visual']),
    likes:  findCol(r,['like','cuori','reaction','mi piace']),
    comm:   findCol(r,['comment','commenti']),
    shares: findCol(r,['share','condivi']),
    saves:  findCol(r,['save','salvat']),
    type:   findCol(r,['type','tipo','format','post_type']),
    cap:    findCol(r,['caption','testo','titolo','title','desc','contenuto']),
  };
  return rows.map(row=>{
    const d = row[c.date]?new Date(row[c.date]):null;
    if(!d||isNaN(d)) return null;
    return { date:d, platform:'ig',
      followers:+row[c.foll]||0, reach:+row[c.reach]||0, impressions:+row[c.imp]||0,
      likes:+row[c.likes]||0, comments:+row[c.comm]||0, shares:+row[c.shares]||0, saves:+row[c.saves]||0,
      type:(row[c.type]||'post').toLowerCase(), caption:row[c.cap]||'' };
  }).filter(Boolean);
}

function normalizeTT(rows){
  if(!rows.length) return [];
  const r=rows[0];
  const c={
    date:   findCol(r,['date','data','giorno','day','periodo']),
    foll:   findCol(r,['follower','fan','subscriber']),
    views:  findCol(r,['view','visual','play','visite']),
    likes:  findCol(r,['like','cuori','mi piace']),
    comm:   findCol(r,['comment','commenti']),
    shares: findCol(r,['share','condivi']),
    title:  findCol(r,['title','titolo','caption','testo','desc','contenuto','video_title']),
  };
  return rows.map(row=>{
    const d = row[c.date]?new Date(row[c.date]):null;
    if(!d||isNaN(d)) return null;
    return { date:d, platform:'tt',
      followers:+row[c.foll]||0, views:+row[c.views]||0,
      likes:+row[c.likes]||0, comments:+row[c.comm]||0, shares:+row[c.shares]||0,
      title:row[c.title]||'' };
  }).filter(Boolean);
}

// ═══════════════════════════════════════════════════════
// FILE LOADING
// ═══════════════════════════════════════════════════════
function dropFile(e, plat){
  e.preventDefault();
  document.getElementById('zone-'+plat).classList.remove('drag');
  const f = e.dataTransfer?.files[0];
  if(f) readFile({files:[f]}, plat);
}

function readFile(input, plat){
  const f = input.files?.[0]; if(!f) return;
  const st = document.getElementById('st-'+plat);
  st.className='uzone-status'; st.textContent='Lettura…';
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const rows = parseCSV(e.target.result);
      if(!rows.length){st.className='uzone-status err';st.textContent='File vuoto o non riconosciuto';return;}
      if(plat==='ig') igRaw=normalizeIG(rows);
      else ttRaw=normalizeTT(rows);
      st.className='uzone-status ok';
      st.textContent='✓ '+rows.length+' righe';
      document.getElementById('zone-'+plat).classList.add('loaded');
      document.getElementById('btn-analyze').disabled=!(igRaw||ttRaw);
      if(input.value!==undefined) input.value='';
    } catch(err){st.className='uzone-status err';st.textContent='Errore: '+err.message;}
  };
  reader.onerror=()=>{st.className='uzone-status err';st.textContent='Impossibile leggere il file';};
  reader.readAsText(f,'UTF-8');
}

// ═══════════════════════════════════════════════════════
// DEMO DATA
// ═══════════════════════════════════════════════════════
function loadDemo(){
  const caps=['Paky: il trailer del nuovo disco','Top 30 rap - commento #14','Take Away: nuovo episodio','Intervista: Marracash','Red Bull 64 Bars','Basement Café season 5','Freestyle Friday','Nuovo disco: recensione','La settimana musicale','ABC: lettera S','Sanremo watchparty','TikTok ha fatto qualcosa di assurdo'];
  const ttitles=['Top 30: Veleno 6 in classifica','Chi è il miglior rapper?','ABC: lettera R','Nuovo Paky - trailer','Take Away feat. Guè','Rap italiano vs americano','Storia Marracash in 60s','Il drop della settimana','De-influencing musicale','Freestyle: chi vince?','Sanremo - il nostro punto','Red Bull 64 Bars: il nuovo episodio'];
  const types=['reel','post','carosello','story'];
  const ig=[], tt=[];
  let igF=875000, ttF=645000;
  const now=new Date();
  for(let i=364;i>=0;i--){
    const d=new Date(now); d.setDate(d.getDate()-i);
    igF+=Math.round(Math.random()*320+80);
    const type=types[Math.floor(Math.random()*4)];
    const reel=type==='reel';
    const base=reel?22000:8000;
    ig.push({date:d,platform:'ig',followers:igF,reach:Math.round(base*(.6+Math.random()*.9)),impressions:Math.round(base*1.4),
      likes:Math.round(base*(.05+Math.random()*.07)*(reel?1.9:1)),comments:Math.round(base*(.008+Math.random()*.012)),
      shares:Math.round(base*(.012+Math.random()*.018)),saves:Math.round(base*(.01+Math.random()*.022)),
      type,caption:caps[Math.floor(Math.random()*caps.length)]});
    ttF+=Math.round(Math.random()*620+280);
    const viral=Math.random()<.08;
    const views=Math.round((viral?950000:58000)*(.5+Math.random()));
    tt.push({date:d,platform:'tt',followers:ttF,views,
      likes:Math.round(views*(.05+Math.random()*.04)),comments:Math.round(views*(.006+Math.random()*.008)),
      shares:Math.round(views*(.012+Math.random()*.02)),
      title:ttitles[Math.floor(Math.random()*ttitles.length)]});
  }
  igRaw=ig; ttRaw=tt;
  ['ig','tt'].forEach(p=>{
    document.getElementById('st-'+p).className='uzone-status ok';
    document.getElementById('st-'+p).textContent='✓ Demo: 365 righe';
    document.getElementById('zone-'+p).classList.add('loaded');
  });
  document.getElementById('btn-analyze').disabled=false;
}

// ═══════════════════════════════════════════════════════
// FILTER & UTILS
// ═══════════════════════════════════════════════════════
function filter(data){
  if(!data||!data.length) return [];
  if(activePeriod>=99999) return data;
  const cut=new Date(); cut.setDate(cut.getDate()-activePeriod);
  return data.filter(r=>r.date>=cut);
}

function fmt(n){
  n=Math.round(n);
  if(Math.abs(n)>=1e9) return (n/1e9).toFixed(1)+'B';
  if(Math.abs(n)>=1e6) return (n/1e6).toFixed(1)+'M';
  if(Math.abs(n)>=1000) return (n/1000).toFixed(1)+'K';
  return String(n);
}

function mkChart(id, type, labels, datasets, opts={}){
  if(charts[id]) charts[id].destroy();
  const el=document.getElementById(id); if(!el) return;
  charts[id]=new Chart(el,{type,data:{labels,datasets},options:{
    responsive:true, maintainAspectRatio:false,
    plugins:{legend:{display:false},tooltip:{backgroundColor:'#1A1A1A',titleColor:'#fff',bodyColor:'rgba(255,255,255,0.6)',cornerRadius:8,padding:10,borderColor:'rgba(255,255,255,0.05)',borderWidth:1}},
