        return `<div class="rbar-row"><div class="rbar-label">${t}</div><div class="rbar-track"><div class="rbar-fill" style="width:${pct}%;background:var(--k)"></div></div><div class="rbar-val">${fmt(avg)}</div></div>`;}).join('')}
