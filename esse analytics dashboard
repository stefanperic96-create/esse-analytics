function renderCalendario(){
  const ig=filter(igRaw), tt=filter(ttRaw);
  if(!ig.length&&!tt.length){document.getElementById('b-calendario').innerHTML='<div class="empty">Carica i dati</div>';return;}
  const all=[...ig,...tt].sort((a,b)=>b.date-a.date);
  const latest=all[0]?.date||new Date();
  const year=latest.getFullYear(), month=latest.getMonth();
  const months=['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno','Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];
  const dayMap={};
  all.forEach(r=>{
    if(r.date.getFullYear()===year&&r.date.getMonth()===month){
      const d=r.date.getDate();
      if(!dayMap[d])dayMap[d]=[];
      dayMap[d].push(r);
    }
  });
  let maxE=0;
  Object.values(dayMap).forEach(posts=>{const e=posts.reduce((s,r)=>s+(r.likes||0)+(r.comments||0)+(r.shares||0)+(r.saves||0)+(r.views||0)*0.05,0);if(e>maxE)maxE=e;});
  let first=new Date(year,month,1).getDay();first=(first+6)%7;
  const dim=new Date(year,month+1,0).getDate();
  const days=['Lun','Mar','Mer','Gio','Ven','Sab','Dom'];

  const now2=new Date(),w1s=new Date(now2);w1s.setDate(w1s.getDate()-7);
  const w2s=new Date(now2);w2s.setDate(w2s.getDate()-14);
  const w1e=all.filter(r=>r.date>=w1s).reduce((s,r)=>s+(r.likes||0)+(r.comments||0)+(r.shares||0)+(r.saves||0),0);
  const w2e=all.filter(r=>r.date>=w2s&&r.date<w1s).reduce((s,r)=>s+(r.likes||0)+(r.comments||0)+(r.shares||0)+(r.saves||0),0);
  const score=Math.min(Math.round(w1e/Math.max(all.length/4,1)/100),100);
  const delta=w2e>0?Math.round((w1e-w2e)/w2e*100):0;

  let calHTML=`<div class="cal-grid"><div></div>${days.map(d=>`<div class="cal-hdr">${d}</div>`).join('')}`;
  calHTML+=`<div></div>`.repeat(first);
  for(let d=1;d<=dim;d++){
    const posts=dayMap[d]||[];
    const eng=posts.reduce((s,r)=>s+(r.likes||0)+(r.comments||0)+(r.shares||0)+(r.saves||0)+(r.views||0)*0.05,0);
    const iv=maxE>0?eng/maxE:0;
    const hasIG=posts.some(p=>p.platform==='ig'), hasTT=posts.some(p=>p.platform==='tt');
    const bg=iv>0.65?'#1A1A1A':iv>0.35?`rgba(26,26,26,${(0.1+iv*0.5).toFixed(2)})`:'var(--g1)';
    const tc=iv>0.65?'var(--y)':'var(--k)';
    calHTML+=`<div class="cal-day" style="background:${bg}" title="${posts.length} post">
      <div class="cal-num" style="color:${tc}">${d}</div>
      ${posts.length?`<div class="cal-posts" style="color:${iv>0.65?'rgba(245,242,51,0.5)':'var(--g3)'}">${posts.length}</div>`:''}
      <div class="cal-dots">
        ${hasIG?`<div class="cal-dot" style="background:var(--ig)"></div>`:''}
        ${hasTT?`<div class="cal-dot" style="background:${iv>0.65?'var(--y)':'var(--k)'}"></div>`:''}
      </div>
    </div>`;
  }
  calHTML+='</div>';

  const weeks=['Sett 1','Sett 2','Sett 3','Sett 4'];
  const igW=[0,0,0,0],ttW=[0,0,0,0];
  ig.filter(r=>r.date.getMonth()===month&&r.date.getFullYear()===year).forEach(r=>{const w=Math.min(Math.floor((r.date.getDate()-1)/7),3);igW[w]++;});
  tt.filter(r=>r.date.getMonth()===month&&r.date.getFullYear()===year).forEach(r=>{const w=Math.min(Math.floor((r.date.getDate()-1)/7),3);ttW[w]++;});

  document.getElementById('b-calendario').innerHTML=`
    <div class="charts-equal anim anim-d1">
      <div class="chart-card yellow">
        <div class="cc-label">Performance settimana</div>
        <div class="cc-title">Score</div>
        <div class="score-num">${score}</div>
        <div style="font-size:12px;color:rgba(26,26,26,0.5);margin-top:5px;">su 100 · ${delta>=0?'+':''}${delta}% vs settimana precedente</div>
        <div class="score-bar-track"><div class="score-bar-fill" style="width:${score}%"></div></div>
      </div>
      <div class="chart-card">
        <div class="cc-label">Frequenza</div>
        <div class="cc-title">Post per settimana · ${months[month]}</div>
        <div class="canvas-wrap" style="height:130px;margin-top:8px"><canvas id="ch-cal-freq"></canvas></div>
        <div class="legend" style="margin-top:10px;">
          <div class="leg-item"><div class="leg-sq" style="background:#E1306C"></div>Instagram</div>
          <div class="leg-item"><div class="leg-sq" style="background:#1A1A1A"></div>TikTok</div>
        </div>
      </div>
    </div>
    ${secLabel(months[month]+' '+year)}
    <div class="chart-card anim anim-d2">
      <div class="cc-label">Calendario editoriale</div>
      <div class="cc-title">${months[month]} ${year} · intensità colore = engagement</div>
      ${calHTML}
      <div style="display:flex;align-items:center;gap:6px;margin-top:12px;">
        <span style="font-size:10px;color:var(--g3);">Basso</span>
        ${[0.05,0.12,0.25,0.4,0.6,0.8,1].map(v=>`<div style="width:18px;height:18px;border-radius:5px;background:rgba(26,26,26,${v})"></div>`).join('')}
        <span style="font-size:10px;color:var(--g3);">Alto</span>
        <span style="margin-left:10px;"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--ig);margin-right:4px;"></span><span style="font-size:10px;color:var(--g3);">IG</span></span>
        <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--k);margin-right:4px;"></span><span style="font-size:10px;color:var(--g3);">TT</span></span>
      </div>
    </div>`;

  setTimeout(()=>mkChart('ch-cal-freq','bar',weeks,[{data:igW,backgroundColor:'#E1306C',borderRadius:6,borderSkipped:false},{data:ttW,backgroundColor:'#1A1A1A',borderRadius:6,borderSkipped:false}],{scales:{x:{grid:{display:false},ticks:{color:'#C8C8C3',font:{size:10}}},y:{grid:{color:'rgba(0,0,0,0.04)'},border:{display:false},ticks:{color:'#C8C8C3',stepSize:1,font:{size:10}}}}}),60);
}

