      {label:'esse',data:[Math.round(igF/9600),Math.round(ttF/7600),parseFloat(igER)/4.5*100,parseFloat(ttER)/7*100,avgR/480,avgV/1900],borderColor:'#F5F233',backgroundColor:'rgba(245,242,51,0.15)',borderWidth:2.5,pointBackgroundColor:'#F5F233',pointRadius:4,pointHoverRadius:6},
      {label:'Media',data:[44,37,40,46,25,20],borderColor:'rgba(255,255,255,0.2)',backgroundColor:'rgba(255,255,255,0.05)',borderWidth:1.5,pointBackgroundColor:'rgba(255,255,255,0.2)',pointRadius:3,borderDash:[4,4]},
    ]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{r:{min:0,max:100,ticks:{display:false,stepSize:25},grid:{color:'rgba(255,255,255,0.06)'},pointLabels:{font:{size:10,family:'Barlow'},color:'rgba(255,255,255,0.4)'},angleLines:{color:'rgba(255,255,255,0.06)'}}}}});
